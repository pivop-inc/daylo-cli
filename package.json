{
  "name": "@pivop/daylo",
  "version": "0.1.0",
  "description": "JSON-first Bun CLI for the Daylo smart-scale API.",
  "keywords": [
    "bun",
    "cli",
    "daylo",
    "smart-scale",
    "tanita",
    "weight",
    "withings"
  ],
  "homepage": "https://daylo.cc",
  "bugs": {
    "url": "https://github.com/pivop-inc/daylo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pivop-inc/daylo.git"
  },
  "bin": {
    "daylo": "apps/cli/bin/daylo.ts"
  },
  "workspaces": [
    "apps/*"
  ],
  "files": [
    "apps/cli/bin",
    "apps/cli/src",
    "docs/spec.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "bun --filter '*' test",
    "typecheck": "bun --filter '*' typecheck",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "packageManager": "bun@1.3.11"
}
