{
  "name": "daylo",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "daylo": "./apps/cli/bin/daylo.ts"
  },
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "bun --filter '*' test",
    "typecheck": "bun --filter '*' typecheck",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "packageManager": "bun@1.3.11"
}
